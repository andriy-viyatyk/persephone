---
title: "App Object Model — Target Architecture"
---

%%{init: {
  "theme": "dark",
  "themeVariables": {
    "fontSize": "14px"
  }
}}%%

graph TB
  %% ===== CONSUMERS =====
  subgraph Consumers["Consumers"]
    direction LR
    UI["App UI<br/><i>React components</i>"]
    Scripts["Scripts<br/><i>F5 / Script Panel</i>"]
    AI["AI Bot<br/><i>Claude / other</i>"]
    Plugins["Plugins<br/><i>webview-based</i>"]
  end

  %% ===== ADAPTERS =====
  subgraph Adapters["Access Adapters"]
    direction LR
    ReactHooks["React Hooks<br/><i>useApp, usePage</i>"]
    ScriptCtx["Script Context<br/><i>app, page globals</i>"]
    ToolAdapter["Tool Adapter<br/><i>flat function calls</i>"]
    PluginBridge["Plugin Bridge<br/><i>postMessage API</i>"]
  end

  UI --> ReactHooks
  Scripts --> ScriptCtx
  AI --> ToolAdapter
  Plugins --> PluginBridge

  %% ===== OBJECT MODEL =====
  subgraph ObjectModel["Object Model — Public API"]
    direction TB

    App["<b>app</b><br/>IApp"]

    subgraph CoreServices["Core Services"]
      direction LR
      Pages["<b>app.pages</b><br/>IPageCollection"]
      UI_IF["<b>app.ui</b><br/>IUserInterface"]
      Settings["<b>app.settings</b><br/>ISettings"]
      FS["<b>app.fs</b><br/>IFileSystem"]
      Window["<b>app.window</b><br/>IWindow"]
      Editors["<b>app.editors</b><br/>IEditorRegistry"]
      Recent["<b>app.recent</b><br/>IRecentFiles"]
    end

    subgraph ShellServices["app.shell — IShell"]
      direction LR
      Shell["<b>app.shell</b><br/>OS integration, spawn"]
      FileSearch["<b>.fileSearch</b><br/>IFileSearchService"]
      Version["<b>.version</b><br/>IVersionService"]
      Encryption["<b>.encryption</b><br/>IEncryptionService"]
      Scripting["<b>.scripting</b><br/>IScriptingService"]
    end

    subgraph PageInterfaces["Page Interfaces"]
      direction LR
      Page["<b>page</b><br/>IPage"]
      TextPage["ITextEditor"]
      BrowserPage["IBrowserEditor"]
      GridPage["IGridEditor"]
      NotebookPage["INotebookEditor"]
      TodoPage["ITodoEditor"]
      LinksPage["ILinksEditor"]
      MarkdownPage["IMarkdownEditor"]
    end

    App --> Pages
    App --> UI_IF
    App --> Settings
    App --> FS
    App --> Window
    App --> Editors
    App --> Recent
    App --> Shell

    Shell --- FileSearch
    Shell --- Version
    Shell --- Encryption
    Shell --- Scripting

    Pages -- "active / find / open" --> Page
    Page -. "asText()" .-> TextPage
    Page -. "asBrowser()" .-> BrowserPage
    Page -. "asGrid()" .-> GridPage
    Page -. "asNotebook()" .-> NotebookPage
    Page -. "asTodo()" .-> TodoPage
    Page -. "asLinks()" .-> LinksPage
    Page -. "asMarkdown()" .-> MarkdownPage
  end

  ReactHooks --> App
  ScriptCtx --> App
  ScriptCtx --> Page
  ToolAdapter --> App
  PluginBridge --> App

  %% ===== PLATFORM SERVICES =====
  subgraph PlatformServices["Platform Services — Cross-Process"]
    direction LR
    FileSvc["File Service<br/><i>read, write, dialogs</i>"]
    WindowSvc["Window Service<br/><i>state, control</i>"]
    DownloadSvc["Download Service<br/><i>progress, history</i>"]
    SearchSvc["Search Service<br/><i>file content search</i>"]
    BrowserSvc["Browser Service<br/><i>webview bridge</i>"]
    VersionSvc["Version Service<br/><i>update check</i>"]
  end

  FS --> FileSvc
  Window --> WindowSvc
  BrowserPage --> BrowserSvc
  BrowserPage --> DownloadSvc
  FileSearch --> SearchSvc
  Version --> VersionSvc

  %% ===== INFRASTRUCTURE =====
  subgraph Infrastructure["Infrastructure"]
    direction LR
    State["Reactive State<br/><i>TOneState / Zustand</i>"]
    Events["Event System<br/><i>Subscription</i>"]
    IPC["IPC Transport<br/><i>ipcRenderer/ipcMain</i>"]
    Registry["Editor Registry<br/><i>lazy loading</i>"]
  end

  PlatformServices --> IPC
  ObjectModel --> State
  ObjectModel --> Events
  Editors --> Registry

  %% ===== MAIN PROCESS =====
  subgraph MainProcess["Main Process"]
    direction LR
    Controllers["Backend Controllers<br/><i>file, window, download,<br/>search, browser, version</i>"]
    NativeSvc["Native APIs<br/><i>Electron, Node.js, OS</i>"]
  end

  IPC --> Controllers
  Controllers --> NativeSvc

  %% ===== STYLING =====
  classDef consumer fill:#4a5568,stroke:#718096,color:#fff
  classDef adapter fill:#553c9a,stroke:#805ad5,color:#fff
  classDef interface fill:#2b6cb0,stroke:#4299e1,color:#fff
  classDef page fill:#2c7a7b,stroke:#38b2ac,color:#fff
  classDef shell fill:#5b4a1e,stroke:#d69e2e,color:#fff
  classDef service fill:#744210,stroke:#d69e2e,color:#fff
  classDef infra fill:#4a5568,stroke:#a0aec0,color:#e2e8f0
  classDef main fill:#742a2a,stroke:#fc8181,color:#fff

  class UI,Scripts,AI,Plugins consumer
  class ReactHooks,ScriptCtx,ToolAdapter,PluginBridge adapter
  class App,Pages,UI_IF,Settings,FS,Window,Editors,Recent interface
  class Page,TextPage,BrowserPage,GridPage,NotebookPage,TodoPage,LinksPage,MarkdownPage page
  class Shell,FileSearch,Version,Encryption,Scripting shell
  class FileSvc,WindowSvc,DownloadSvc,SearchSvc,BrowserSvc,VersionSvc service
  class State,Events,IPC,Registry infra
  class Controllers,NativeSvc main
