graph TD
    CTX["ScriptContext"] --> AW["AppWrapper<br/><i>implements IApp</i>"]
    CTX --> PW["PageWrapper<br/><i>implements IPage</i>"]
    CTX --> RE["React"]

    AW --> |"app.pages"| PCW["PageCollectionWrapper<br/><i>implements IPageCollection</i>"]
